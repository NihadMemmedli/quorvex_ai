# Production Environment Configuration
# Copy this file to .env.prod and fill in the values
# IMPORTANT: Never commit .env.prod to version control

# ===== REQUIRED - Application will not start without these =====

# Database
POSTGRES_USER=playwright
POSTGRES_PASSWORD=postgres
POSTGRES_DB=playwright_agent

# Authentication - REQUIRED
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=dev-secret-key-change-in-production

# AI Provider Credentials - Z.ai GLM Coding Plan (Anthropic-compatible)
# Get your key from the Z.ai API Keys page and set it here.
QUORVEX_LLM_PROVIDER=anthropic_compatible
QUORVEX_LLM_API_KEY=your-zai-api-key-here
QUORVEX_LLM_API_KEYS=
QUORVEX_LLM_BASE_URL=https://api.z.ai/api/anthropic
# Legacy Anthropic-compatible aliases are still supported by SDK clients.
ANTHROPIC_AUTH_TOKEN=your-zai-api-key-here
ANTHROPIC_AUTH_TOKENS=
ANTHROPIC_API_KEY=your-zai-api-key-here
# Claude Code OAuth is not used for Z.ai API-key mode; keep empty unless switching back to Claude subscription auth.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_MODEL=glm-5.1
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.1
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5-turbo
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.5-air
ANTHROPIC_CHAT_MODEL=glm-5-turbo
QUORVEX_LLM_LIGHT_MODEL=glm-4.5-air
QUORVEX_LLM_STANDARD_MODEL=glm-5-turbo
QUORVEX_LLM_DEEP_MODEL=glm-5.1
QUORVEX_LLM_TOOL_DEEP_MODEL=glm-5.1
QUORVEX_LLM_CHAT_MODEL=glm-5-turbo
QUORVEX_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_ENABLE_CHAT_THINKING=false
API_TIMEOUT_MS=3000000

# MinIO (Object Storage for backups)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=playwright-backups
MINIO_BUCKET_ARTIFACTS=playwright-artifacts

# ===== RECOMMENDED - Set for production =====

# CORS - Comma-separated list of allowed origins
# Example: https://qa.company.internal,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://host.docker.internal:3000

# OpenAI (for memory system embeddings)
OPENAI_API_KEY=

# Registration and auth (set REQUIRE_AUTH=true for production)
ALLOW_REGISTRATION=true
REQUIRE_AUTH=false

# Initial admin user (created automatically on first startup)
# Change these before your first 'make prod-dev'
INITIAL_ADMIN_EMAIL=admin@test.com
INITIAL_ADMIN_PASSWORD=Admin123!@#

# ===== OPTIONAL - Defaults are usually fine =====

# Logging
LOG_LEVEL=INFO

# Parallel execution
PARALLEL_MODE_ENABLED=true
DEFAULT_PARALLELISM=10

# Resource management - concurrent operation limits
# Prevents resource exhaustion with 20+ concurrent users
MAX_CONCURRENT_AGENTS=8
MAX_CONCURRENT_EXPLORATIONS=5
MAX_CONCURRENT_PRD=3

# Resource timeouts (seconds) - auto-release stale slots
AGENT_TIMEOUT_SECONDS=1800
EXPLORATION_TIMEOUT_SECONDS=1800
PRD_TIMEOUT_SECONDS=600

# Backup retention (days)
BACKUP_RETENTION=30
ARCHIVE_RETENTION=90
ARCHIVE_HOT_DAYS=30
ARCHIVE_TOTAL_DAYS=90

# Frontend API URL (for server-side rendering)
NEXT_PUBLIC_API_URL=http://localhost:8001
QUORVEX_PUBLIC_API_URL=http://localhost:8001

# MinIO ports (if not using defaults)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ===== CORPORATE PROXY - Set if behind a corporate proxy =====

# HTTP_PROXY=http://proxy.company.internal:8080
# HTTPS_PROXY=http://proxy.company.internal:8080
# NO_PROXY=localhost,127.0.0.1,db,redis,minio,backend,frontend

# ===== TLS/NGINX - Required if using nginx profile =====

# Place your TLS certificates in ./nginx/certs/:
# - cert.pem (certificate)
# - key.pem (private key)
#
# To generate self-signed certs for testing:
# openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#   -keyout nginx/certs/key.pem \
#   -out nginx/certs/cert.pem \
#   -subj "/CN=playwright.company.internal"
