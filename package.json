{
  "name": "quorvex-ai",
  "version": "1.0.0",
  "description": "Quorvex AI — Intelligent test automation platform that converts natural language specifications into production-ready Playwright tests.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "npx playwright test",
    "test:e2e:memory": "sh -c 'PLAYWRIGHT_START_WEB_SERVER=true BASE_URL=${BASE_URL:-http://localhost:3000} API_BASE=${API_BASE:-http://localhost:8001} npx playwright test tests/e2e/memory.spec.ts --project=${PLAYWRIGHT_PROJECT:-chromium}'"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "ai",
    "agent",
    "claude",
    "nlp",
    "test-generation",
    "self-healing",
    "typescript",
    "llm",
    "nextjs",
    "fastapi",
    "load-testing",
    "security-testing"
  ],
  "author": "Nihad Mammadli",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "@types/node": "^25.6.0",
    "appium": "^3.4.2",
    "appium-mcp": "^1.73.0",
    "appium-xcuitest-driver": "^11.4.0",
    "dotenv": "^17.3.1",
    "webdriverio": "^9.27.1"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.141",
    "@playwright/mcp": "^0.0.75",
    "playwright": "1.57.0",
    "playwright-core": "1.57.0",
    "undici-types": "^8.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NihadMemmedli/quorvex_ai.git"
  },
  "bugs": {
    "url": "https://github.com/NihadMemmedli/quorvex_ai/issues"
  },
  "homepage": "https://nihadmemmedli.github.io/quorvex_ai/"
}
