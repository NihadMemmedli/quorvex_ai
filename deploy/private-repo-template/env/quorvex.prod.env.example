# Private production environment for mytest.idda.az.
# Copy to env/quorvex.prod.env in the private deploy repo and replace every
# placeholder there. Never commit the real env file to a public repository.

# Public source checkout containing docker-compose.prod.yml and app scripts.
QUORVEX_SOURCE_DIR=/opt/quorvex_ai

# GHCR namespace that the public tag release workflow publishes to.
# The deploy script expands v1.2.3 into:
#   ghcr.io/<owner>/quorvex-ai/backend:v1.2.3
QUORVEX_IMAGE_NAMESPACE=ghcr.io/example-org/quorvex-ai

# Server-local persistent data root. bootstrap.sh creates these directories.
QUORVEX_DATA_ROOT=/srv/quorvex/mytest
QUORVEX_PUBLIC_URL=https://mytest.idda.az
QUORVEX_COMPOSE_PROFILES=standard
COMPOSE_PROJECT_NAME=quorvex-mytest

# Same-origin browser API mode. Keep blank so browser requests go through
# /backend-proxy and the Next.js server routes internally to backend:8001.
QUORVEX_PUBLIC_API_URL=
NEXT_PUBLIC_API_URL=
INTERNAL_API_URL=http://backend:8001

# Public company origin.
ALLOWED_ORIGINS=https://mytest.idda.az
TEMPORAL_CORS_ORIGINS=https://mytest.idda.az
VNC_PUBLIC_WS_URL=wss://mytest.idda.az/websockify

# Bind app service ports to localhost; the company nginx config is the public edge.
FRONTEND_BIND=127.0.0.1:3000
BACKEND_BIND=127.0.0.1:8001
VNC_BIND=127.0.0.1:6080
MINIO_API_BIND=127.0.0.1:9000
MINIO_CONSOLE_BIND=127.0.0.1:9001
TEMPORAL_BIND=127.0.0.1:7233
TEMPORAL_UI_BIND=127.0.0.1:8233
HERMES_API_BIND=127.0.0.1:8642
HERMES_DASHBOARD_BIND=127.0.0.1:9119
ZAP_BIND=127.0.0.1:8090

# Authentication. Use long random values from a password manager or vault.
REQUIRE_AUTH=true
ALLOW_REGISTRATION=false
JWT_SECRET_KEY=replace-with-at-least-32-random-bytes
INITIAL_ADMIN_EMAIL=admin@mytest.idda.az
INITIAL_ADMIN_PASSWORD=replace-with-strong-initial-admin-password

# Database.
POSTGRES_USER=quorvex
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=quorvex
DATABASE_URL=postgresql://quorvex:replace-with-strong-postgres-password@db:5432/quorvex

# MinIO backup and artifact storage.
MINIO_ROOT_USER=quorvex-minio
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
MINIO_BUCKET=quorvex-backups
MINIO_BUCKET_ARTIFACTS=quorvex-artifacts

# LLM credentials and routing. Only one provider is active for the core app
# runtime at deploy time. Z.ai GLM is the default production provider.
QUORVEX_ACTIVE_LLM_PROVIDER=zai
ZAI_API_KEY=replace-with-zai-api-key
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional Hermes agent runtime. Set QUORVEX_ACTIVE_LLM_PROVIDER=hermes to use
# Hermes for agent runs while keeping HERMES_UPSTREAM_PROVIDER as the provider
# Hermes should call upstream.
HERMES_API_KEY=
HERMES_API_URL=http://hermes:8642
HERMES_MODEL=hermes-agent
HERMES_UPSTREAM_PROVIDER=zai
HERMES_ENABLED=false
QUORVEX_AGENT_RUNTIME=claude_sdk

# Derived runtime values. The deploy scripts and install-server.sh map the
# active provider key above into these canonical app variables.
QUORVEX_LLM_PROVIDER=anthropic_compatible
QUORVEX_LLM_BASE_URL=https://api.z.ai/api/anthropic
QUORVEX_LLM_API_KEY=
QUORVEX_LLM_API_KEYS=
QUORVEX_LLM_LIGHT_MODEL=glm-4.5-air
QUORVEX_LLM_STANDARD_MODEL=glm-5-turbo
QUORVEX_LLM_DEEP_MODEL=glm-5.1
QUORVEX_LLM_TOOL_DEEP_MODEL=glm-5.1
QUORVEX_LLM_CHAT_MODEL=glm-5-turbo
QUORVEX_EMBEDDING_MODEL=text-embedding-3-small

# Legacy Anthropic-compatible aliases used by SDK clients. ANTHROPIC_AUTH_TOKEN
# is populated from the active provider key for Z.ai, OpenRouter, and Anthropic
# modes; ANTHROPIC_API_KEY above remains the real Anthropic provider slot.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_AUTH_TOKENS=
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_MODEL=glm-5.1
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.1
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5-turbo
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.5-air
ANTHROPIC_CHAT_MODEL=glm-5-turbo
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_ENABLE_CHAT_THINKING=false
API_TIMEOUT_MS=3000000

# Runtime sizing.
BROWSER_WORKER_REPLICAS=4
AGENT_WORKER_REPLICAS=2
K6_WORKER_REPLICAS=3
PLAYWRIGHT_WORKERS=4
DEFAULT_PARALLELISM=4
MAX_CONCURRENT_AGENTS=8
MAX_CONCURRENT_EXPLORATIONS=5
MAX_CONCURRENT_PRD=3

# Optional outbound proxy.
# HTTP_PROXY=http://proxy.company.internal:8080
# HTTPS_PROXY=http://proxy.company.internal:8080
NO_PROXY=localhost,127.0.0.1,db,redis,minio,zap,backend,frontend,temporal,hermes

# Backups and retention.
BACKUP_RETENTION=30
ARCHIVE_HOT_DAYS=30
ARCHIVE_TOTAL_DAYS=90
