# Safe production environment example.
# Copy this into a private deploy repo and replace every placeholder there.

# Image references published by .github/workflows/release-images.yml on tags.
QUORVEX_BACKEND_IMAGE=ghcr.io/example-org/quorvex-ai/backend:v1.2.3
QUORVEX_BACKEND_SLIM_IMAGE=ghcr.io/example-org/quorvex-ai/backend-slim:v1.2.3
QUORVEX_FRONTEND_IMAGE=ghcr.io/example-org/quorvex-ai/frontend:v1.2.3
QUORVEX_BROWSER_WORKER_IMAGE=ghcr.io/example-org/quorvex-ai/browser-worker:v1.2.3
QUORVEX_K6_WORKER_IMAGE=ghcr.io/example-org/quorvex-ai/k6-worker:v1.2.3

# Public company origin. Leave public API overrides blank so browser API calls
# use same-origin /backend-proxy and the Next.js server routes internally to
# http://backend:8001 via INTERNAL_API_URL.
ALLOWED_ORIGINS=https://app.example.com
TEMPORAL_CORS_ORIGINS=https://app.example.com
QUORVEX_PUBLIC_API_URL=
NEXT_PUBLIC_API_URL=
VNC_PUBLIC_WS_URL=wss://app.example.com/websockify

# Authentication. Use long, random values from a secret manager.
REQUIRE_AUTH=true
ALLOW_REGISTRATION=false
JWT_SECRET_KEY=replace-with-at-least-32-random-bytes
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=replace-with-strong-initial-admin-password

# Database.
POSTGRES_USER=quorvex
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=quorvex
DATABASE_URL=postgresql://quorvex:replace-with-strong-postgres-password@db:5432/quorvex

# MinIO backup and artifact storage.
MINIO_ROOT_USER=quorvex-minio
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
MINIO_BUCKET=quorvex-backups
MINIO_BUCKET_ARTIFACTS=quorvex-artifacts

# LLM credentials and routing. Only one provider is active for the core app
# runtime at deploy time. Z.ai GLM is the default production provider.
QUORVEX_ACTIVE_LLM_PROVIDER=zai
ZAI_API_KEY=replace-with-zai-api-key
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional Hermes agent runtime. Set QUORVEX_ACTIVE_LLM_PROVIDER=hermes and
# keep HERMES_UPSTREAM_PROVIDER as the upstream provider Hermes should call.
HERMES_API_KEY=
HERMES_API_URL=http://hermes:8642
HERMES_MODEL=hermes-agent
HERMES_UPSTREAM_PROVIDER=zai
HERMES_ENABLED=false
QUORVEX_AGENT_RUNTIME=claude_sdk

# Derived runtime values. Deployment scripts map the active provider key above
# into these canonical app variables.
QUORVEX_LLM_PROVIDER=anthropic_compatible
QUORVEX_LLM_BASE_URL=https://api.z.ai/api/anthropic
QUORVEX_LLM_API_KEY=
QUORVEX_LLM_LIGHT_MODEL=glm-4.5-air
QUORVEX_LLM_STANDARD_MODEL=glm-5-turbo
QUORVEX_LLM_DEEP_MODEL=glm-5.1
QUORVEX_LLM_TOOL_DEEP_MODEL=glm-5.1
QUORVEX_LLM_CHAT_MODEL=glm-5-turbo

# Legacy Anthropic-compatible aliases used by SDK clients.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_AUTH_TOKENS=
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_MODEL=glm-5.1
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.1
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5-turbo
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.5-air
ANTHROPIC_CHAT_MODEL=glm-5-turbo

# Runtime sizing.
BROWSER_WORKER_REPLICAS=4
AGENT_WORKER_REPLICAS=2
K6_WORKER_REPLICAS=3
PLAYWRIGHT_WORKERS=4
DEFAULT_PARALLELISM=4
MAX_CONCURRENT_AGENTS=8
MAX_CONCURRENT_EXPLORATIONS=5
MAX_CONCURRENT_PRD=3

# Public host ports. Restrict these at the firewall or override in a private
# compose overlay if the corporate reverse proxy runs on the same host.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8233
HERMES_API_PORT=8642
HERMES_DASHBOARD_PORT=9119

# Corporate outbound proxy. Leave HTTP_PROXY/HTTPS_PROXY unset unless outbound
# AI/API calls must traverse a corporate proxy.
# HTTP_PROXY=http://proxy.company.internal:8080
# HTTPS_PROXY=http://proxy.company.internal:8080
NO_PROXY=localhost,127.0.0.1,db,redis,minio,zap,backend,frontend,temporal,hermes

# Backups and retention.
BACKUP_RETENTION=30
ARCHIVE_HOT_DAYS=30
ARCHIVE_TOTAL_DAYS=90
